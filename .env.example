# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── Banco de dados ────────────────────────────────────────
DB_PATH=./db/gamefix.db

# ── Autenticação JWT ──────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-segura-em-producao
JWT_EXPIRES_IN=8h

# ── RabbitMQ (CloudAMQP) ──────────────────────────────────
# Cole aqui a AMQP URL copiada do painel CloudAMQP
# Exemplo: amqps://usuario:senha@hostname.rmq.cloudamqp.com/vhost
RABBITMQ_URL=amqps://SEU_USUARIO:SUA_SENHA@SEU_HOST.rmq.cloudamqp.com/SEU_VHOST
